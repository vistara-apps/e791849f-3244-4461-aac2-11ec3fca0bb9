# Base MiniKit Configuration
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_MINIKIT_PROJECT_ID=your_minikit_project_id_here

# Farcaster Integration
NEXT_PUBLIC_FARCASTER_HUB_URL=https://hub.farcaster.xyz
NEXT_PUBLIC_FARCASTER_APP_FID=your_farcaster_app_fid

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ENABLED=true
NEXT_PUBLIC_ANALYTICS_PROJECT_ID=your_analytics_project_id

# App Configuration
NEXT_PUBLIC_APP_NAME=RightCheck
NEXT_PUBLIC_APP_URL=https://your-app-domain.com
NEXT_PUBLIC_APP_DESCRIPTION="Know Your Rights, Instantly"

# Feature Flags
NEXT_PUBLIC_ENABLE_PURCHASES=true
NEXT_PUBLIC_ENABLE_SOCIAL_SHARING=true
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Development Settings
NODE_ENV=development
NEXT_PUBLIC_DEBUG_MODE=false
